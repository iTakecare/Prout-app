# Copiez ce fichier en .env et renseignez les valeurs.
# En production, ce fichier est généré automatiquement par le workflow
# de déploiement (.github/workflows/deploy.yml) — vous n'avez rien à faire.

# --- Application ---
APP_DOMAIN=prout-app.vibecodestudio.io

# --- Base de données PostgreSQL ---
POSTGRES_USER=prout
POSTGRES_PASSWORD=remplacez-par-un-mot-de-passe-fort
POSTGRES_DB=prout

# --- Reverse proxy Traefik (détectés automatiquement au déploiement) ---
PROXY_NETWORK=deploy_internal
HTTPS_ENTRYPOINT=websecure
CERT_RESOLVER=letsencrypt

# --- Développement local uniquement ---
# DATABASE_URL=postgres://prout:prout@localhost:5432/prout
