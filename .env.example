# Copiez ce fichier en .env et renseignez les valeurs.

# --- Application ---
APP_DOMAIN=prout-app.vibecodestudio.io

# --- Base de données PostgreSQL ---
POSTGRES_USER=prout
POSTGRES_PASSWORD=remplacez-par-un-mot-de-passe-fort
POSTGRES_DB=prout

# --- Reverse proxy (Traefik) ---
# Nom du réseau Docker externe partagé avec le reverse proxy du VPS.
PROXY_NETWORK=web
# Nom du certresolver Traefik configuré sur le VPS (Let's Encrypt).
CERT_RESOLVER=le

# --- Développement local uniquement ---
# URL de connexion utilisée quand l'app tourne hors de Docker (npm run dev).
# DATABASE_URL=postgres://prout:prout@localhost:5432/prout
